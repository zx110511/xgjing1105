!     def memoize(self, ttl_s: float = 300, cache_level: str = "l1"):
!         """装饰器: 缓存函数结果"""
  
!         def decorator(func):
!             @functools.wraps(func)
!             def wrapper(*args, **kwargs):
!                 key_parts = [func.__name__, json.dumps(args, default=str), json.dumps(kwargs, default=str)]
!                 cache_key = hashlib.md5(":".join(key_parts).encode()).hexdigest()
  
!                 if cache_level == "l1":
