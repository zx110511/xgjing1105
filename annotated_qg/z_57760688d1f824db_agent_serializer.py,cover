! class AgentIntrospector:
!     """
!     Agent自省器 — 无侵入式序列化
  
!     通过inspect模块自省Agent类，自动提取:
!       - 静态属性 (AGENT_ID, AGENT_NAME, LAYER, ROLE, EMOJI, CAPABILITIES, TOOLS, MCP_SERVER)
!       - 健康检查 (health_check)
!       - 统计信息 (get_stats)
!       - 方法签名 (灵境gRPC proto生成用)
  
!     适用场景: 旧Agent无to_dict方法，但需要灵境服务描述
!     """
  
!     EXPECTED_STATIC_ATTRS = [
!         "AGENT_ID", "AGENT_NAME", "LAYER", "ROLE", "EMOJI",
!         "CAPABILITIES", "TOOLS", "MCP_SERVER"
!     ]
  
!     DEFAULT_VALUES = {
!         "AGENT_ID": "unknown",
!         "AGENT_NAME": "UnknownAgent",
!         "LAYER": "L0",
!         "ROLE": "未定义",
!         "EMOJI": "🤖",
!         "CAPABILITIES": [],
!         "TOOLS": [],
!         "MCP_SERVER": "unknown"
!     }
  
!     @classmethod
!     def inspect_agent_class(cls, agent_class: Type) -> Dict[str, Any]:
!         """自省Agent类 — 提取所有静态属性"""
!         result = {}
!         for attr in cls.EXPECTED_STATIC_ATTRS:
!             result[attr] = getattr(agent_class, attr, cls.DEFAULT_VALUES.get(attr, ""))
!         return result
  
!     @classmethod
!     def inspect_agent_instance(cls, instance) -> Dict[str, Any]:
!         """自省Agent实例 — 提取静态属性+运行时状态"""
!         result = cls.inspect_agent_class(type(instance))
  
!         if hasattr(instance, 'health_check'):
!             try:
!                 result["health"] = instance.health_check()
!             except Exception as e:
!                 result["health"] = {"status": "error", "message": str(e)}
!         else:
!             result["health"] = {"status": "unknown", "message": "无health_check方法"}
  
!         if hasattr(instance, 'get_stats'):
!             try:
!                 result["stats"] = instance.get_stats()
!             except Exception as e:
!                 result["stats"] = {"error": str(e)}
!         else:
!             result["stats"] = {}
  
!         result["has_health_check"] = hasattr(instance, 'health_check')
!         result["has_get_stats"] = hasattr(instance, 'get_stats')
!         result["has_to_dict"] = hasattr(instance, 'to_dict')
!         result["public_methods"] = cls._get_public_methods(instance)
  
!         return result
  
!     @classmethod
!     def serialize_instance(cls, instance) -> str:
!         """将Agent实例序列化为JSON"""
!         data = cls.inspect_agent_instance(instance)
!         data["serialized_at"] = datetime.now().isoformat()
!         data["schema_version"] = "1.0.0"
!         return json.dumps(data, ensure_ascii=False, indent=2)
  
!     @classmethod
!     def _get_public_methods(cls, instance) -> List[str]:
!         """获取公开方法列表 (灵境gRPC proto生成用)"""
!         methods = []
!         for name, method in inspect.getmembers(instance, predicate=inspect.ismethod):
!             if not name.startswith('_'):
!                 try:
!                     sig = inspect.signature(method)
!                     params = []
!                     for param_name, param in sig.parameters.items():
!                         if param_name != 'self':
!                             annotation = str(param.annotation) if param.annotation != inspect.Parameter.empty else "Any"
!                             params.append(f"{param_name}: {annotation}")
!                     methods.append(f"{name}({', '.join(params)})")
!                 except Exception:
!                     methods.append(name)
!         return methods
  
  
