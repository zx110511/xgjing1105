! class SourceAdapter(ABC):
!     @abstractmethod
!     def collect(self, metric_def: MetricDef) -> Tuple[Any, Optional[Dict[str, Any]]]:
!         pass
  
!     @abstractmethod
!     def replay(self, anchor_info: Dict[str, Any]) -> Any:
!         pass
  
  
