### 三、核心组件设计

#### 3.1 指标注册中心（Metric Registry）

每个统计指标需要预先定义元数据，支持动态注册：

```python
@dataclass
class MetricDef:
    name: str                     # 唯一标识，如 "system.cpu.usage"
    metric_type: str              # counter, gauge, histogram, summary
    source_type: str              # file, proc, log, kafka, api, derived
    source_config: dict           # 具体来源配置
    aggregation: str              # sum, avg, max, min, p99
    anchor_policy: str            # "full" | "sample" | "none" 锚定粒度
    retention_days: int = 30
    validation_enabled: bool = True

# 示例：监控CPU使用率
MetricDef(
    name="system.cpu.usage",
    metric_type="gauge",
    source_type="proc",
    source_config={"path": "/proc/stat", "parser": "cpu_parser"},
    aggregation="avg",
    anchor_policy="sample"        # 每5秒采集一次，保存采样时刻的/proc/stat快照
)

# 示例：监控HTTP请求总数（来自access.log）
MetricDef(
    name="http.requests.total",
    metric_type="counter",
    source_type="log",
    source_config={"path": "/var/log/nginx/access.log", "pattern": r'"GET|POST'},
    anchor_policy="full",         # 完整锚定到日志文件行范围
)
```

#### 3.2 采集适配器接口

```python
class SourceAdapter(ABC):
    """采集适配器基类"""
    @abstractmethod
    def collect(self, metric_def: MetricDef) -> CollectResult:
        """返回 (value, anchor_info)"""
        pass

    @abstractmethod
    def replay(self, anchor_info: dict) -> Any:
        """根据锚定信息重放原始数据，用于验证"""
        pass

# 实现示例：文件日志适配器
class LogFileAdapter(SourceAdapter):
    def collect(self, metric_def):
        file_path = metric_def.source_config["path"]
        pattern = metric_def.source_config["pattern"]
        # 记录读取范围（文件大小、inode、偏移）
        stat = os.stat(file_path)
        with open(file_path, 'r') as f:
            f.seek(self.last_offset)   # 增量读取
            lines = f.readlines()
            count = sum(1 for line in lines if re.search(pattern, line))
        anchor = {
            "type": "log_file",
            "path": file_path,
            "inode": stat.st_ino,
            "offset_start": self.last_offset,
            "offset_end": f.tell(),
            "file_hash_snapshot": self.compute_hash(file_path, self.last_offset, f.tell())
        }
        self.last_offset = f.tell()
        return CollectResult(value=count, anchor=anchor)

    def replay(self, anchor_info):
        # 根据 offset 范围重新读取并计数
        with open(anchor_info["path"], 'rb') as f:
            f.seek(anchor_info["offset_start"])
            data = f.read(anchor_info["offset_end"] - anchor_info["offset_start"])
