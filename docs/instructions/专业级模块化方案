### 2. 模块命名规范（TN-Naming v1.0）

#### 2.1 命名模式矩阵

| 模块类型 | 命名模式 | 示例 | 说明 |
|----------|----------|------|------|
| **Engine引擎** | `[Domain]Engine` | `ICMEEngine`, `EvolutionEngine`, `WorkflowEngine` | 核心计算单元 |
| **Driver驱动器** | `[Capability]Driver` | `DeepSeekDriver`, `TraeCaptureDriver` | 外部能力接入 |
| **Manager管理器** | `[Resource]Manager` | `BackupManager`, `StateManager` | 资源生命周期管理 |
| **Scheduler调度器** | `[Scope]Scheduler` | `IntelligentScheduler`, `AgentScheduler` | 任务/资源调度 |
| **Registry注册表** | `[Entity]Registry` | `SkillRegistry`, `ModuleRegistry` | 实体注册与发现 |
| **Gateway网关** | `[Protocol]Gateway` | `MessageGateway`, `APIGateway` | 协议转换与路由 |
| **Hook钩子** | `[Event]Hook` | `EnforcementHook`, `CaptureHook` | 事件拦截与处理 |
| **Bridge桥接** | `[System]Bridge` | `AsyncBridge`, `TVPBridge`, `MemoryBridge` | 异构系统集成 |
| **Pipeline管道** | `[Process]Pipeline` | `SkillExtractionPipeline`, `IngestionPipeline` | 流水线处理 |
| **Agent代理** | `[Role]Agent` | `BuildAgent`, `TestAgent`, `RecoveryAgent` | 自主任务执行 |
| **Service服务** | `[Function]Service` | `EmbeddingService`, `SummarizerService` | 功能性服务 |
| **Monitor监控器** | `[Target]Monitor` | `HealthMonitor`, `PerformanceMonitor` | 系统状态监控 |
| **Checker检查器** | `[Aspect]Checker` | `IntegrityChecker`, `ComplianceChecker` | 合规性/完整性校验 |

#### 2.2 命名约束规则

```yaml
rules:
  length:
    min: 3
    max: 40
    error: "模块名长度必须在3-40字符之间"

  format:
    pattern: "^[A-Z][a-zA-Z0-9]*$"
    description: "PascalCase，首字母大写，无下划线/连字符"

  forbidden_patterns:
    - "^Utils$"           # 过于通用
    - "^Helper$"          # 职责不明
    - "^Common$"          # 边界不清
    - "^[A-Z]{1,2}$"     # 缩写不清晰

  required_components:
    - domain_noun: "必须包含领域相关名词（如Memory, Learning, Evolution）"
    - capability_verb: "建议包含能力动词（如Capture, Process, Manage）"

  examples:
    good:
      - "DeepSeekDriver"        # ✅ 清晰表达：DeepSeek能力驱动器
      - "AutoCapture"            # ✅ 自动捕获功能
      - "EnforcementHook"        # ✅ 强制执行的钩子
      - "IntelligentScheduler"   # ✅ 智能调度器
    bad:
      - "DSDriver"               # ❌ 缩写不清晰
      - "Manager"                # ❌ 过于通用
      - "Util"                   # ❌ 职责不明
```

### 3. 模块元数据定义（ModuleMetadata Schema）

```typescript
interface TianjiModuleDefinition {
  // === 基础标识 ===
  module_id: string;                    // 唯一标识符 (UUID v4)
  module_name: string;                  // 模块名 (PascalCase)
  module_display_name: string;          // 显示名称 (中文)
  module_version: string;               // 语义化版本 (MAJOR.MINOR.PATCH-CODENAME)

  // === 分类归属 ===
  tier: TianjiModuleTier;               // 所属层级
  category: string;                     // 分类标签 (如'brain', 'enforcement')
  subcategory?: string;                 // 子分类 (如'deepseek', 'capture')

  // === 职责描述 ===
  responsibility: string;               // 单一职责描述 (一句话)
  capabilities: string[];               // 能力列表 (如['event_perception', 'decision_making'])

  // === 依赖关系 ===
  dependencies: ModuleDependency[];     // 依赖的其他模块
  dependents: string[];                 // 被哪些模块依赖

  // === 接口定义 ===
  public_api: MethodSignature[];        // 对外暴露的API方法
  events_published: EventDef[];         // 发布的事件
  events_subscribed: EventDef[];        // 订阅的事件

  // === 配置参数 ===
  config_schema: JSONSchema;            // 配置项的JSON Schema
  default_config: Record<string, any>;  // 默认配置值

  // === 运行时状态 ===
  lifecycle_state: ModuleLifecycleState; // 生命周期状态
  health_metrics: HealthMetricDef[];    // 健康指标定义

  // === 统计与监控 ===
  stats_interface: StatsMethodSignature; // get_stats()方法的返回类型
  key_metrics: KeyMetricDef[];          // 关键指标列表 (用于Dashboard展示)

  // === 治理信息 ===
  owner: string;                        // 模块负责人
  created_at: ISO8601;                 // 创建时间
  last_modified: ISO8601;              // 最后修改时间
  changelog: ChangelogEntry[];         // 变更日志
}

interface ModuleDependency {
  target_module: string;                // 目标模块名
  dependency_type: 'required' | 'optional' | 'runtime';
  version_constraint: string;           // 版本约束 (如'^1.0.0')
  description: string;                  // 依赖原因
}
```

