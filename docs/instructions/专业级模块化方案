### 六、模块健康指标体系

```python
@dataclass
class ModuleHealthMetrics:
    """
    模块健康指标 - 基于ModuleChallenger的五维扫描模型

    参考：evolution_loop.py中的DEFAULT_HEALTH_METRICS
    """

    # 维度1: 容量健康
    capacity_usage: float = 0.0          # 容量使用率 (0-1)
    capacity_warn_threshold: float = 0.7  # 警告阈值
    capacity_critical_threshold: float = 0.9  # 临界阈值

    # 维度2: 效率健康
    avg_latency_ms: float = 0.0          # 平均延迟（毫秒）
    latency_warn_threshold: float = 500.0  # 警告阈值
    latency_critical_threshold: float = 2000.0  # 临界阈值

    # 维度3: 质量健康
    rejection_rate: float = 0.0          # 拒绝率 (0-1)
    rejection_warn_threshold: float = 0.15  # 警告阈值
    rejection_critical_threshold: float = 0.3  # 临界阈值

    downgrade_rate: float = 0.0          # 降级率 (0-1)
    downgrade_warn_threshold: float = 0.1  # 警告阈值
    downgrade_critical_threshold: float = 0.2  # 临界阈值

    # 维度4: 利用健康
    utilization: float = 0.0             # 利用率 (0-1)
    utilization_warn_threshold: float = 0.1  # 警告阈值（过低）
    utilization_critical_threshold: float = 0.05  # 临界阈值（过低）

    # 维度5: 错误健康
    error_rate: float = 0.0              # 错误率 (0-1)
    error_warn_threshold: float = 0.05   # 警告阈值
    error_critical_threshold: float = 0.1  # 临界阈值

    def calculate_health_score(self) -> float:
        """计算综合健康分 (0-100)"""
        scores = []

        # 容量分（越低越好）
        scores.append(max(0, 100 * (1 - self.capacity_usage)))

        # 效率分（越低越好）
        normalized_latency = min(self.avg_latency_ms / self.latency_critical_threshold, 1.0)
        scores.append(100 * (1 - normalized_latency))

        # 质量分（越低越好）
        scores.append(100 * (1 - self.rejection_rate))
        scores.append(100 * (1 - self.downgrade_rate))

        # 利用分（适中最好，过高或过低都不好）
        optimal_utilization = 0.6
        utilization_score = 100 * (1 - abs(self.utilization - optimal_utilization))
        scores.append(max(0, utilization_score))

        # 错误分（越低越好）
        scores.append(100 * (1 - self.error_rate))

        return sum(scores) / len(scores)

    def get_status(self) -> str:
        """获取健康状态"""
        score = self.calculate_health_score()
        if score >= 80:
            return "healthy"
        elif score >= 60:
            return "degraded"
        else:
            return "unhealthy"
