### 三、模块元数据Schema（TianjiModuleDefinition）

```python
@dataclass
class TianjiModuleDefinition:
    """
    天机模块标准定义 - 完整的元数据schema

    设计理念：
    - 基于"近可分解系统"理论（Herbert Simon）
    - 遵循ISO/IEC 25010软件质量模型
    - 支持可执行架构验证
    """

    # ===== 模块身份标识 =====
    module_id: str                                    # 唯一标识符（如 "icme_engine_v9.0"）
    module_name: str                                  # 简短名称（如 "ICMEEngine"）
    display_name: str                                 # 展示名称（如 "ICME记忆核心引擎"）
    module_version: str = "9.0.0"                     # 模块版本号

    # ===== 分类信息 =====
    tier: ModuleTier                                 # 所属层级
    module_type: ModuleType                          # 模块类型
    domain: str                                      # 业务域（如 "memory_management"）
    sub_domain: Optional[str] = None                 # 子域（如 "consolidation"）

    # ===== 职责描述 =====
    responsibility: str                              # 核心职责（一句话描述）
    capabilities: List[str] = field(default_factory=list)  # 能力清单
    anti_responsibilities: List[str] = field(default_factory=list)  # 不负责什么

    # ===== 依赖关系 =====
    dependencies: List[str] = field(default_factory=list)  # 依赖的module_id列表
    dependents: List[str] = field(default_factory=list)   # 被哪些模块依赖
    dependency_type: str = "strong"                  # 依赖强度: strong/weak/optional

    # ===== 接口定义 =====
    public_api: List[str] = field(default_factory=list)   # 公开API方法名
    internal_api: List[str] = field(default_factory=list) # 内部API（禁止跨模块调用）
    events_published: List[str] = field(default_factory=list)  # 发布的事件类型
    events_subscribed: List[str] = field(default_factory=list)  # 订阅的事件类型

    # ===== 配置参数 =====
    config_schema: Dict[str, Any] = field(default_factory=dict)  # 配置项schema
    default_config: Dict[str, Any] = field(default_factory=dict)  # 默认配置值

    # ===== 运行时状态 =====
    lifecycle_state: str = "initialized"             # 生命周期状态
    health_status: str = "unknown"                   # 健康状态: healthy/degraded/unhealthy
    last_health_check: float = 0.0                   # 最后健康检查时间

    # ===== 统计接口 =====
    stats_interface: Optional[Callable] = None       # get_stats()方法引用
    stats_schema: Dict[str, str] = field(default_factory=dict)  # 统计数据字段说明

    # ===== 进化能力 =====
    evolution_enabled: bool = True                   # 是否启用进化闭环
    evolution_loop: Optional[Any] = None             # EvolutionLoop实例引用
    challenger_config: Dict[str, Any] = field(default_factory=dict)  # Challenger配置

    # ===== 治理信息 =====
    owner: str = "tianji_core_team"                  # 模块负责人/团队
    sla_target: float = 99.9                         # 可用性目标（%）
    change_frequency: str = "low"                    # 变更频率: low/medium/high
    criticality: str = "critical"                    # 关键程度: critical/high/medium/low

    # ===== 元数据 =====
    created_at: float = field(default_factory=time.time)
    updated_at: float = field(default_factory=time.time)
    tags: List[str] = field(default_factory=list)
    metadata: Dict[str, Any] = field(default_factory=dict)

    def to_dict(self) -> Dict:
        """序列化为字典"""
        return {
            "module_id": self.module_id,
            "module_name": self.module_name,
            "display_name": self.display_name,
            "tier": self.tier.value,
            "module_type": self.module_type.value,
            "domain": self.domain,
            "responsibility": self.responsibility,
            "dependencies": self.dependencies,
            "health_status": self.health_status,
            "evolution_enabled": self.evolution_enabled,
            "criticality": self.criticality,
        }
