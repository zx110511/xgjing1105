    def __init__(self):
        self._agent_map: Dict[str, AgentDefinition] = {}
        self._tool_map: Dict[str, MCPToolBinding] = {}
        self._mcp_server_map: Dict[str, List[str]] = {}
        self._build_maps()

    def _build_maps(self):
        for agent in self.AGENT_DEFINITIONS:
            self._agent_map[agent.agent_id] = agent
            if agent.mcp_server not in self._mcp_server_map:
                self._mcp_server_map[agent.mcp_server] = []
            self._mcp_server_map[agent.mcp_server].append(agent.agent_id)

    def get_agent(self, agent_id: str) -> Optional[AgentDefinition]:
        return self._agent_map.get(agent_id)

    def get_agents_by_layer(self, layer: AgentLayer) -> List[AgentDefinition]:
        return [a for a in self.AGENT_DEFINITIONS if a.layer == layer]

    def get_agents_by_mcp_server(self, server: str) -> List[AgentDefinition]:
        return [self._agent_map[aid] for aid in self._mcp_server_map.get(server, [])]

    def get_agents_for_tool(self, tool_name: str) -> List[AgentDefinition]:
        return [a for a in self.AGENT_DEFINITIONS if tool_name in a.tools]

    def generate_registry_json(self) -> dict:
        """生成 _AGENT_REGISTRY.json 内容"""
        agents = {}
        for agent in self.AGENT_DEFINITIONS:
            agents[agent.agent_id] = {
                "name": agent.name,
                "layer": f"L{agent.layer.value}",
                "role": agent.role,
                "emoji": agent.emoji,
                "capabilities": agent.capabilities,
                "tools": agent.tools,
                "mcp_server": agent.mcp_server,
            }
        return {
            "_meta": {
                "source": "core/amim.py",
                "version": self.VERSION,
                "module": self.MODULE_ID,
                "agent_count": len(self.AGENT_DEFINITIONS),
            },
            "agents": agents,
        }

    def generate_capability_matrix(self) -> str:
        """生成 agent_orchestrator.py 中的 AGENT_CAPABILITY_MATRIX 代码"""
        lines = ["AGENT_CAPABILITY_MATRIX: Dict[str, Dict] = {"]
        for agent in self.AGENT_DEFINITIONS:
            lines.append(f'    "{agent.agent_id}": {{'
                         f'"name":"{agent.name}","layer":"L{agent.layer.value}",'
                         f'"role":"{agent.role}","emoji":"{agent.emoji}",')
            capabilities = json.dumps(agent.capabilities, ensure_ascii=False)
            tools = json.dumps(agent.tools, ensure_ascii=False)
            lines.append(f'        "capabilities":{capabilities},')
            lines.append(f'        "tools":{tools}}},')
        lines.append("}")
        return "\n".join(lines)

    def generate_lingjing_services(self) -> dict:
        """生成灵境架构的 AgentService 描述 JSON"""
        services = {}
        for agent in self.AGENT_DEFINITIONS:
            if agent.lingjing_service_id:
                services[agent.lingjing_service_id] = {
                    "agent_id": agent.agent_id,
                    "agent_name": agent.name,
                    "agent_emoji": agent.emoji,
                    "layer": f"L{agent.layer.value}",
                    "port": agent.lingjing_port,
                    "health_endpoint": agent.health_endpoint,
                    "tools": agent.tools,
                    "mcp_server": agent.mcp_server,
                    "grpc_proto": agent.grpc_proto,
                    "capabilities": agent.capabilities,
                }
        return {
            "_meta": {
                "source": "core/amim.py → generate_lingjing_services()",
                "version": self.VERSION,
                "migration_target": "灵境架构 Phase 1+",
            },
            "services": services,
        }

    def validate(self) -> List[str]:
        """验证 Agent↔MCP↔工具 一致性"""
        issues = []
        known_tools = {
            "memory_remember","memory_recall","memory_forget","memory_stats",
            "memory_capacity","memory_consolidate","search_memories","get_memory",
            "list_memories","build_working_representation","run_reflective_cycle",
            "get_session_digest","explain_memory_lineage","tianji_health",
            "tianji_help","tianji_classify","tianji_auto_tag","tianji_summarize",
            "tianji_extract_knowledge","tianji_expand_query","tianji_semantic_search",
            "tianji_intercept","tianji_export","tianji_summarize_conversation",
            "agent_dispatch","system_status","context_extract","rule_evaluate",
            "execute_command","security-scanner","performance-profiler","ops-engine",
        }
        known_mcp = {"tianji-native","agent-framework-global","command-executor",
                     "memory-engine-global","ops-engine","performance-profiler","security-scanner"}

        for agent in self.AGENT_DEFINITIONS:
            if agent.mcp_server not in known_mcp:
                issues.append(f"[{agent.agent_id}] 未知MCP服务器: {agent.mcp_server}")
            for tool in agent.tools:
                if tool not in known_tools:
                    issues.append(f"[{agent.agent_id}] 未知工具: {tool}")

        mcp_coverage = set()
        for agent in self.AGENT_DEFINITIONS:
            mcp_coverage.add(agent.mcp_server)
        for s in known_mcp:
            if s not in mcp_coverage:
                issues.append(f"MCP服务器 {s} 无Agent绑定")

        return issues
