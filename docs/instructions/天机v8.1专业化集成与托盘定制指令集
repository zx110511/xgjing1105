# 1. 在 TianjiTray 类中添加回调方法
def on_{action}(self):
    """{功能描述}"""
    r = api_get("/api/{module}/health")  # 或 api_post()
    if r:
        # 处理成功 → 写文件用notepad展示
        status_file = LOG_DIR / "{action}_result.txt"
        status_file.write_text(json.dumps(r, ensure_ascii=False, indent=2), encoding="utf-8")
        subprocess.Popen(["notepad", str(status_file)])
        log(f"[菜单] {功能描述}完成")
    else:
        log(f"[菜单] {功能描述}失败（服务未就绪）")

# 2. 在 _build_menu() 中按层级插入菜单项
def _build_menu(self):
    return (
        TrayMenuItem("天机记忆系统 v9.0 全能版", None, enabled=False),
        pystray.Menu.SEPARATOR,
        # ═══ 一级菜单 ═══
        TrayMenuItem("📊 系统全貌", self.on_full_status),
        TrayMenuItem("👁 服务状态", self.on_status),
        TrayMenuItem("🌐 打开管理界面", self.on_open_web),
        pystray.Menu.SEPARATOR,
        # ═══ 二级子菜单 ═══
        TrayMenuItem("🧠 AI驾驶中心", pystray.Menu(
            TrayMenuItem("驾驶者状态", self.on_driver_status),
            TrayMenuItem("⚡ 手动深度思考", self.on_deepseek_trigger),
            TrayMenuItem("🧬 手动进化反思", self.on_evolution_trigger),
        )),
        # ... 更多子菜单 ...
        # ═══ 新模块菜单（按此模板添加） ═══
        TrayMenuItem("{菜单图标+标题}", pystray.Menu(
            TrayMenuItem("{子项1}", self.on_{action1}),
            TrayMenuItem("{子项2}", self.on_{action2}),
        )),
        pystray.Menu.SEPARATOR,
        TrayMenuItem("⏸ 暂停/恢复", self.on_toggle_pause),
        TrayMenuItem("🔄 重启服务", self.on_restart),
        pystray.Menu.SEPARATOR,
        TrayMenuItem("⏹ 退出天机", self.on_quit),
    )
